<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="io.github.liuliu.ordermanagement.mapper.UserMapper">

    <resultMap id="UserMap" type="UserEntity">
        <id property="id" column="id"/>
        <result property="username" column="username"/>
        <result property="email" column="email"/>
        <result property="isDeleted" column="is_deleted"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
        <result property="deletedAt" column="deleted_at"/>
    </resultMap>

    <select id="findById" resultMap="UserMap">
        SELECT * FROM users WHERE id = #{id} AND is_deleted = false
    </select>

    <insert id="insert">
        INSERT INTO users (id, username, email, is_deleted, created_at, updated_at)
        VALUES (#{id}, #{username}, #{email}, false, CURRENT_TIMESTAMP, CURRENT_TIMESTAMP)
    </insert>

</mapper>
